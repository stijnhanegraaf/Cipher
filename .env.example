# Optional: initial vault path. The app can also connect a vault at runtime
# via the connect wizard — this is just the default for server start.
# Leave empty and the app will probe common locations (~/Obsidian,
# ~/Documents/Obsidian, sibling `../Obsidian`).
VAULT_PATH=

# Optional: display name / initial for the current user avatar.
# Defaults to "You" / "·" when unset.
# NEXT_PUBLIC_USER_NAME=

# Custom sidebar pins are stored in <vault>/.cipher/sidebar.json.
# Synced automatically with whatever syncs your vault.
